# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Upstash Vector — https://console.upstash.com/vector
# Create an index with a built-in embedding model (e.g. "all-minilm-l6-v2")
UPSTASH_VECTOR_REST_URL=your_upstash_vector_url_here
UPSTASH_VECTOR_REST_TOKEN=your_upstash_vector_token_here
